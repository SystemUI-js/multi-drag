{
    "name": "@system-ui-js/multi-drag-workspace",
    "private": true,
    "version": "0.0.0",
    "description": "Workspace for multi-drag packages and demo.",
    "engines": {
        "node": "^18.14.0 || ^20.0.0 || ^22.0.0 || >=24.0.0"
    },
    "type": "module",
    "workspaces": [
        "packages/*",
        "apps/*"
    ],
    "scripts": {
        "dev": "yarn workspace @system-ui-js/multi-drag-demo dev",
        "build": "yarn build:packages && yarn build:demo",
        "build:all": "yarn build",
        "build:packages": "yarn workspace @system-ui-js/multi-drag-core build && yarn workspace @system-ui-js/multi-drag build",
        "build:demo": "yarn workspace @system-ui-js/multi-drag-demo build",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "yarn test:core && yarn test:web",
        "test:core": "yarn workspace @system-ui-js/multi-drag-core test",
        "test:web": "yarn workspace @system-ui-js/multi-drag test",
        "test:e2e": "sh -c 'yarn dev --host 0.0.0.0 --port 5173 >/tmp/multi-drag-demo-test.log 2>&1 & pid=$!; trap \"kill $pid\" EXIT; until curl -sf http://localhost:5173/ >/dev/null; do sleep 1; done; playwright test'",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:all": "yarn test && yarn test:e2e",
        "prepublishOnly": "yarn test:all && yarn build",
        "release:core": "yarn workspace @system-ui-js/multi-drag-core build && yarn workspace @system-ui-js/multi-drag-core npm publish --access public",
        "release:web": "yarn workspace @system-ui-js/multi-drag-core build && yarn workspace @system-ui-js/multi-drag build && yarn workspace @system-ui-js/multi-drag npm publish --access public"
    },
    "devDependencies": {
        "@eslint/js": "9.39.2",
        "@playwright/test": "^1.54.2",
        "@system-ui-js/development-base": "0.1.1",
        "@types/jest": "^30.0.0",
        "@types/node": "^20.5.0",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-prettier": "^5.5.4",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-sonarjs": "^3.0.5",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.0.5",
        "playwright": "^1.54.2",
        "prettier": "^3.7.4",
        "prettier-config-standard": "^7.0.0",
        "ts-jest": "^29.4.1",
        "typescript": "^5.0.2",
        "typescript-eslint": "^8.50.0",
        "vite": "^4.4.5",
        "vite-plugin-checker": "^0.6.2",
        "vconsole": "^3.15.1"
    },
    "dependencies": {
        "loglevel": "^1.9.2"
    },
    "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
